# Server port and allowed frontend origin
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Supabase — publishable key is used to verify caller tokens (RLS still applies)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Service role key — server-only, bypasses RLS. NEVER expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx
